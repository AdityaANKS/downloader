# =============================================================================
# Personal Media Downloader - Environment Configuration
# =============================================================================
# Copy this file to .env and modify as needed.
# Do NOT commit .env to version control!
# =============================================================================

# ===== PATHS =====
# Base directory for all downloads
BASE_DIR=C:\Users\adity\scraper

# Custom paths (leave empty to use defaults under BASE_DIR)
VIDEO_DIR=
AUDIO_DIR=
TEMP_DIR=

# ===== QUALITY DEFAULTS =====
# Video: 8K, 4K, 1440p, 1080p, 720p, 480p, 360p, 240p, best, worst
DEFAULT_VIDEO_QUALITY=1080p

# Audio: 320, 256, 192, 128, flac, best
DEFAULT_AUDIO_QUALITY=192

# Video format: mp4, mkv, webm, mov, avi
DEFAULT_VIDEO_FORMAT=mp4

# Audio format: mp3, m4a, flac, wav, opus, ogg
DEFAULT_AUDIO_FORMAT=mp3

# ===== DOWNLOAD SETTINGS =====
MAX_CONCURRENT_DOWNLOADS=3
RETRY_ATTEMPTS=3
REQUEST_TIMEOUT=30
CHUNK_SIZE=1048576

# ===== BOT MODULE (Optional) =====
# Enable anti-detection features
USE_BOT_MODULE=false

# Rate limiting (requests per minute)
RATE_LIMIT_RPM=30

# ===== PROXY (Optional) =====
ENABLE_PROXY=false
PROXY_URL=
# Examples:
# PROXY_URL=http://user:pass@host:port
# PROXY_URL=socks5://host:port

# ===== COOKIES =====
# Path to cookies file (Netscape format)
# COOKIES_FILE=cookies/youtube.txt

# ===== LOGGING =====
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_TO_CONSOLE=true

# ===== EMBEDDING =====
EMBED_THUMBNAIL=true
EMBED_METADATA=true
SAVE_THUMBNAIL_SEPARATELY=false

# ===== FILE ORGANIZATION =====
ORGANIZE_BY_PLATFORM=true
ORGANIZE_BY_PLAYLIST=true
MAX_FILENAME_LENGTH=200

# ===== EXTERNAL TOOLS =====
# Leave empty to auto-detect from PATH
FFMPEG_PATH=
# YT_DLP_PATH=